# Base URL for TT/backend-monolith (must match `src/config/api.config.js` default).
# Expo: use EXPO_PUBLIC_* so the value is available in the app bundle.
#
# Examples:
#   Web / iOS simulator on same machine:
#     EXPO_PUBLIC_BASE_URL=http://localhost:3500
#   Android emulator (host PC):
#     EXPO_PUBLIC_BASE_URL=http://10.0.2.2:3500
#   Physical phone on same Wi‑Fi (replace with your PC LAN IP):
#     EXPO_PUBLIC_BASE_URL=http://192.168.1.50:3500
#
EXPO_PUBLIC_BASE_URL=http://localhost:3500
